{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Synergos",
  "version": "0.1.0",
  "identifier": "io.ludiars.synergos.tauri",
  "build": {
    "beforeBuildCommand": "npm --prefix frontend run build",
    "beforeDevCommand": "npm --prefix frontend run dev",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Synergos",
        "width": 1200,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
